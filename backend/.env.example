# =====================================================================
#  متغيّرات البيئة — انسخ هذا الملف إلى .env وعدّل القيم
#  لا تُودِع .env في git (مُضاف إلى .gitignore)
# =====================================================================

# رابط اتصال قاعدة البيانات
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_db

# مفتاح توقيع JWT — اجعله طويلاً وعشوائياً في الإنتاج
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars

# مدة صلاحية الرمز
JWT_EXPIRES_IN=2h

# منفذ الخادم
PORT=3000

# جولات تشفير bcrypt
BCRYPT_ROUNDS=10

# بيئة التشغيل: development | production | test
NODE_ENV=development
